# Research Pipeline Configuration
# Copy this file to config.yaml and customize for your needs.

settings:
  # Model for generating summaries (uses Claude CLI)
  summary_model: claude-sonnet

  # Default digest format
  digest_format: markdown

  # Where to save digests
  digest_location: ./digests

  # Day to generate weekly rollups (lowercase)
  rollup_day: sunday

  # Delivery configuration (optional)
  delivery:
    email:
      enabled: false          # TODO: Enable after verifying kaiak.io domain in Resend
      provider: resend
      recipient: "ben@kaiak.io"
      from_email: "research@kaiak.io"
      # from_email: "research@yourdomain.com"  # Required for resend/sendgrid
      send_on: digest          # digest = after each topic, rollup = weekly only

    drive:
      enabled: false
      method: rclone           # Only rclone supported currently
      remote_name: gdrive      # Your rclone remote name
      remote_path: "Research"  # Folder in Google Drive

    notebooklm:
      enabled: false           # Flag only - setup is manual in NotebookLM
      drive_path: "Research"   # Confirms path for NotebookLM to source from


# Research topics - add as many as you need
topics:
  # AI in Education research
  ai-in-education:
    frequency: weekly
    keywords:
      - "large language model education"
      - "LLM tutoring"
      - "generative AI learning"
      - "ChatGPT students"
      - "AI literacy"
      - "automated assessment"
    sources:
      - arxiv
      - rss
    rss_feeds:
      - "https://blog.google/technology/ai/rss/"
      - "https://openai.com/blog/rss/"
      - "https://www.anthropic.com/rss.xml"
      - "https://deepmind.google/blog/rss.xml"
    summary_focus: "practical applications for K-12 education, policy implications, student outcomes"

  # Leadership and organizational research
  leadership:
    frequency: biweekly
    keywords:
      - "organizational decision making"
      - "leadership cognition"
      - "management cognitive load"
      - "distributed leadership"
      - "principal effectiveness"
    sources:
      - arxiv
      - rss
    rss_feeds:
      - "https://hbr.org/feed"
      - "https://sloanreview.mit.edu/feed/"
    summary_focus: "actionable frameworks for school leaders, decision-making models"

  # Systems thinking and organizational design
  systems-thinking:
    frequency: weekly
    keywords:
      - "systems thinking"
      - "organizational design"
      - "complex adaptive systems"
      - "multi-agent systems"
      - "process automation"
      - "workflow orchestration"
    sources:
      - arxiv
      - rss
    rss_feeds:
      - "https://www.lesswrong.com/feed.xml"
      - "https://blog.langchain.dev/rss/"
    summary_focus: "systemic approaches to organizational challenges, automation patterns"

  # Practical AI tools and workflows
  practical-ai:
    frequency: every_3_days
    keywords:
      - "AI agent"
      - "LLM tool use"
      - "retrieval augmented generation"
      - "prompt engineering"
      - "AI workflow automation"
    sources:
      - arxiv
      - rss
    rss_feeds:
      - "https://simonwillison.net/atom/everything/"
      - "https://lilianweng.github.io/index.xml"
      - "https://www.latent.space/feed"
    summary_focus: "implementable techniques, tool comparisons, practical workflows"


# Notes:
# - Keywords are combined with OR for broader searches
# - arXiv is always free and doesn't require an API key
# - For web search, set BRAVE_SEARCH_KEY in your .env file
# - RSS feeds should point to valid feed URLs
# - summary_focus guides Claude's summarization priorities

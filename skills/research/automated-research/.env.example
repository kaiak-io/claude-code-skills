# Research Pipeline Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# Web Search (optional - for Brave Search source)
BRAVE_SEARCH_KEY=

# Email Delivery - Gmail (choose one provider)
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=

# Email Delivery - Resend (alternative)
RESEND_API_KEY=

# Email Delivery - SendGrid (alternative)
SENDGRID_API_KEY=

# Google Scholar via SerpAPI (optional - if you want scholarly search)
SERPAPI_KEY=

# Tavily (optional - alternative web search)
TAVILY_KEY=
